{
  "name": "0-waste-shop-food",
  "version": "1.0.0",
  "type": "module",
  "description": "0 Waste Shop Food — Trusted Circular Marketplace",
  "main": "index.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build --mode production",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-check.mjs",
    "cap:sync": "vite build --mode production && npx cap sync",
    "cap:android": "vite build --mode production && npx cap sync android && npx cap open android",
    "cap:ios": "vite build --mode production && npx cap sync ios && npx cap open ios",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aryamusthofa/0waste-goto-production.git"
  },
  "keywords": [
    "0waste",
    "circular-economy",
    "marketplace",
    "react",
    "capacitor",
    "android"
  ],
  "author": "0Waste Team",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.100.1",
    "html2canvas": "^1.4.1",
    "i18next": "^25.10.10",
    "jspdf": "^2.5.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.5",
    "@vitejs/plugin-legacy": "^5.4.2",
    "@vitejs/plugin-react": "^4.3.1",
    "terser": "^5.31.6",
    "vite": "^5.1.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ]
}
