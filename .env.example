# =============================================
# 0waste Shop Food — Environment Variables
# Copy file ini jadi .env dan isi nilainya
# File .env JANGAN di-commit ke GitHub!
# =============================================

# --- Supabase (WAJIB) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- AI Provider untuk EcoChat (isi salah satu atau semua) ---
# Groq — gratis, cepat (https://console.groq.com)
VITE_GROQ_API_KEY=

# Google Gemini (https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=

# Pilih provider default: "groq" | "gemini" | "openai"
VITE_AI_PROVIDER=groq
