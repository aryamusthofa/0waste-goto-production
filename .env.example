# --- Supabase (WAJIB) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- AI Provider ---
# Gemini API Key diatur melalui Supabase Edge Functions (backend secret).
VITE_AI_PROVIDER=gemini
